# ══════════════════════════════════════════
# 富得財富管理 · 後端環境金鑰範本
# 複製這個檔案，改名為 .env，再填入真實的值
# .env 檔案本身「絕對不要」上傳到 GitHub 或分享出去
# ══════════════════════════════════════════

# ── LINE Messaging API ──
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── Supabase ──
# 注意：SUPABASE_URL 只填「專案網址」本身，不要加 /rest/v1/ 等路徑
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron 保護金鑰（自動產生一組隨機字串即可，用來保護排程端點）──
CRON_SECRET=
